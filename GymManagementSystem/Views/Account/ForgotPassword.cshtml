@{
    ViewData["Title"] = "Forgot Password";
    Layout = "~/Views/Shared/_StaticLayout.cshtml";
}

<div class="container d-flex justify-content-center align-items-center"
     style="min-height:80vh;">
    <div class="card shadow-lg border-0 rounded-4" style="width:440px;">
        <div class="card-body p-5">

            <div class="text-center mb-4">
                <div style="width:60px;height:60px;border-radius:14px;
                    background:linear-gradient(135deg,#ffc107,#ff8c00);
                    display:flex;align-items:center;justify-content:center;
                    margin:0 auto 16px;font-size:1.5rem;">
                    🔐
                </div>
                <h3 class="fw-bold">Forgot Password?</h3>
                <p class="text-muted small">
                    Enter your email and we'll send you a reset link
                </p>
            </div>

            @if (TempData["ForgotSuccess"] != null)
            {
                <div class="alert alert-success rounded-3 text-center">
                    <i class="bi bi-check-circle-fill me-2"></i>
                    <strong>Email sent!</strong><br />
                    <small>
                        Check your inbox for the password reset link.
                        Check spam folder if not found.
                    </small>
                </div>
            }
            else
            {
                <form asp-action="ForgotPassword" method="post">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger rounded-3 small">
                            <div asp-validation-summary="All"></div>
                        </div>
                    }

                    <div class="mb-4">
                        <label class="form-label fw-semibold">
                            Email Address
                        </label>
                        <div class="input-group">
                            <span class="input-group-text bg-light">
                                <i class="bi bi-envelope"></i>
                            </span>
                            <input type="email" name="email"
                                   class="form-control"
                                   placeholder="Enter your registered email"
                                   autocomplete="off" required />
                        </div>
                    </div>

                    <button type="submit"
                            class="btn btn-warning w-100 fw-bold py-2">
                        <i class="bi bi-send me-1"></i>
                        Send Reset Link
                    </button>
                </form>
            }

            <hr class="my-4" />
            <p class="text-center small text-muted mb-0">
                Remember your password?
                <a asp-action="Login" class="text-warning fw-bold">
                    Sign in
                </a>
            </p>

        </div>
    </div>
</div>
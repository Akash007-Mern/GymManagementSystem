@{
    ViewData["Title"] = "Goodbye";
    Layout = "~/Views/Shared/_StaticLayout.cshtml";
}

<style>
    .logout-wrapper {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
        flex-direction: column;
        text-align: center;
        color: white;
    }

    /* Animated circle */
    .logout-circle {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        background: linear-gradient(135deg, #ffc107, #ff8c00);
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 30px;
        animation: popIn 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards, pulse 1.5s ease-in-out 0.6s infinite;
    }

        .logout-circle i {
            font-size: 3rem;
            color: #1a1a2e;
        }

    /* Wave goodbye text */
    .goodbye-text {
        font-size: 2.5rem;
        font-weight: 700;
        opacity: 0;
        transform: translateY(20px);
        animation: slideUp 0.6s ease 0.4s forwards;
    }

    .goodbye-sub {
        font-size: 1rem;
        opacity: 0;
        color: rgba(255,255,255,0.6);
        animation: slideUp 0.6s ease 0.6s forwards;
    }

    /* Progress bar */
    .logout-progress-wrap {
        width: 200px;
        height: 4px;
        background: rgba(255,255,255,0.1);
        border-radius: 10px;
        margin: 30px auto 0;
        overflow: hidden;
        opacity: 0;
        animation: slideUp 0.6s ease 0.8s forwards;
    }

    .logout-progress-bar {
        height: 100%;
        width: 0%;
        background: linear-gradient(90deg, #ffc107, #ff8c00);
        border-radius: 10px;
        animation: fillBar 2.5s ease 1s forwards;
    }

    .redirect-text {
        font-size: 0.8rem;
        color: rgba(255,255,255,0.4);
        margin-top: 12px;
        opacity: 0;
        animation: slideUp 0.6s ease 1s forwards;
    }

    /* Floating particles */
    .particle {
        position: fixed;
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: #ffc107;
        opacity: 0;
        animation: floatUp 3s ease-in infinite;
    }

    /* Keyframes */
    @@keyframes popIn {
        0% {
            transform: scale(0);
            opacity: 0;
        }

        100% {
            transform: scale(1);
            opacity: 1;
        }
    }

    @@keyframes pulse {
        0%, 100% {
            transform: scale(1);
            box-shadow: 0 0 0 0 rgba(255,193,7,0.4);
        }

        50% {
            transform: scale(1.05);
            box-shadow: 0 0 0 15px rgba(255,193,7,0);
        }
    }

    @@keyframes slideUp {
        0% {
            opacity: 0;
            transform: translateY(20px);
        }

        100% {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes fillBar {
        0% {
            width: 0%;
        }

        100% {
            width: 100%;
        }
    }

    @@keyframes floatUp {
        0% {
            transform: translateY(100vh) scale(0);
            opacity: 0;
        }

        10% {
            opacity: 0.6;
        }

        90% {
            opacity: 0.2;
        }

        100% {
            transform: translateY(-100px) scale(1);
            opacity: 0;
        }
    }
</style>

<!-- Floating particles -->
<div class="particle" style="left:10%; animation-delay:0s; animation-duration:4s;"></div>
<div class="particle" style="left:25%; animation-delay:0.5s; animation-duration:3.5s; background:#ff8c00;"></div>
<div class="particle" style="left:50%; animation-delay:1s; animation-duration:5s;"></div>
<div class="particle" style="left:70%; animation-delay:0.3s; animation-duration:3s; background:#ff8c00;"></div>
<div class="particle" style="left:85%; animation-delay:1.5s; animation-duration:4.5s;"></div>
<div class="particle" style="left:40%; animation-delay:0.8s; animation-duration:3.8s;"></div>
<div class="particle" style="left:60%; animation-delay:1.2s; animation-duration:4.2s; background:#ff8c00;"></div>
<div class="particle" style="left:90%; animation-delay:0.2s; animation-duration:3.2s;"></div>

<div class="logout-wrapper">

    <!-- Animated icon -->
    <div class="logout-circle">
        <i class="bi bi-lightning-charge-fill"></i>
    </div>

    <!-- Text -->
    <h2 class="goodbye-text">Goodbye! 👋</h2>
    <p class="goodbye-sub">You have been safely logged out from FitZone</p>

    <!-- Progress bar -->
    <div class="logout-progress-wrap">
        <div class="logout-progress-bar"></div>
    </div>
    <p class="redirect-text">Redirecting to home page...</p>

</div>

@section Scripts {
    <script>
        // Redirect to home after 3.5 seconds
        setTimeout(function () {
            window.location.href = '/';
        }, 3500);
    </script>
}
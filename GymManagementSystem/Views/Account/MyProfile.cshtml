@model GymManagementSystem.Models.ApplicationUser
@{
    ViewData["Title"] = "My Profile";
    Layout = "~/Views/Shared/_StaticLayout.cshtml";
}

<div class="container-fluid">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="page-title">
                <i class="bi bi-person-circle text-warning me-2"></i>
                My Profile
            </h2>
            <p class="page-subtitle">Manage your membership and payments</p>
        </div>
    </div>

    <div class="row g-4">

        <!-- LEFT — Profile Card -->
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4 text-center">

                    <!-- Avatar -->
                    <div style="width:90px;height:90px;border-radius:50%;
                        background:linear-gradient(135deg,#ffc107,#ff8c00);
                        display:flex;align-items:center;justify-content:center;
                        margin:0 auto 16px;font-size:2.5rem;">
                        <i class="bi bi-person-fill text-dark"></i>
                    </div>

                    <h4 class="fw-bold">@Model.FullName</h4>
                    <span class="badge bg-warning text-dark px-3 py-2 mb-3">
                        <i class="bi bi-person-check me-1"></i> Member
                    </span>

                    <hr />

                    <div class="text-start">
                        <div class="d-flex align-items-center gap-2 mb-3">
                            <div style="width:35px;height:35px;border-radius:8px;
                                background:#fff8e1;display:flex;
                                align-items:center;justify-content:center;">
                                <i class="bi bi-envelope text-warning"></i>
                            </div>
                            <div>
                                <div style="font-size:0.7rem;color:#aaa;">
                                    Email
                                </div>
                                <div class="fw-semibold small">@Model.Email</div>
                            </div>
                        </div>

                        <div class="d-flex align-items-center gap-2 mb-3">
                            <div style="width:35px;height:35px;border-radius:8px;
                                background:#fff8e1;display:flex;
                                align-items:center;justify-content:center;">
                                <i class="bi bi-phone text-warning"></i>
                            </div>
                            <div>
                                <div style="font-size:0.7rem;color:#aaa;">Phone</div>
                                <div class="fw-semibold small">
                                    @(Model.PhoneNumber ?? "Not provided")
                                </div>
                            </div>
                        </div>

                        <div class="d-flex align-items-center gap-2">
                            <div style="width:35px;height:35px;border-radius:8px;
                                background:#fff8e1;display:flex;
                                align-items:center;justify-content:center;">
                                <i class="bi bi-shield-check text-warning"></i>
                            </div>
                            <div>
                                <div style="font-size:0.7rem;color:#aaa;">Role</div>
                                <div class="fw-semibold small">@Model.Role</div>
                            </div>
                        </div>
                    </div>

                    <hr />

                    <a asp-controller="Account" asp-action="Logout"
                       class="btn btn-danger w-100 fw-bold">
                        <i class="bi bi-box-arrow-right me-1"></i> Logout
                    </a>
                </div>
            </div>
        </div>

        <!-- RIGHT — Membership + Plans -->
        <div class="col-md-8">

            <!-- Current Membership Status -->
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3">
                        <i class="bi bi-card-checklist text-warning me-2"></i>
                        Current Membership
                    </h5>

                    @if (ViewBag.CurrentPayment != null)
                    {
                        var payment = ViewBag.CurrentPayment as GymManagementSystem.Models.Payment;
                        var daysLeft = (payment.ValidUntil.ToDateTime(TimeOnly.MinValue) - DateTime.Today).Days;
                        var isActive = daysLeft > 0;

                        <div class="rounded-4 p-4 text-white mb-3"
                             style="background: @(isActive ? "linear-gradient(135deg,#43e97b,#38f9d7)" : "linear-gradient(135deg,#f5576c,#f093fb)")">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <div class="fw-bold fs-5">
                                        @payment.Plan?.PlanName
                                    </div>
                                    <div class="opacity-75 small">
                                        Valid until:
                                        @payment.ValidUntil.ToString("dd MMM yyyy")
                                    </div>
                                </div>
                                <div class="text-end">
                                    @if (isActive)
                                    {
                                        <span class="badge bg-white text-success fw-bold px-3 py-2">
                                            <i class="bi bi-circle-fill me-1"
                                               style="font-size:0.4rem;"></i>
                                            Active
                                        </span>
                                        <div class="mt-2 opacity-75 small">
                                            @daysLeft days remaining
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="badge bg-white text-danger fw-bold px-3 py-2">
                                            Expired
                                        </span>
                                    }
                                </div>
                            </div>
                        </div>

                        @if (!isActive || daysLeft <= 7)
                        {
                            <div class="alert alert-warning rounded-3 small">
                                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                                @if (!isActive)
                                {
                                    <strong>Your membership has expired!</strong>
                                    <span>Please renew your plan below.</span>
                                }
                                else
                                {
                                    <strong>Your membership expires in @daysLeft days!</strong>
                                    <span>Consider renewing now.</span>
                                }
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center py-4">
                            <i class="bi bi-card-checklist text-muted"
                               style="font-size:3rem;"></i>
                            <h6 class="mt-2 text-muted">No active membership</h6>
                            <p class="text-muted small">
                                Choose a plan below to get started!
                            </p>
                        </div>
                    }
                </div>
            </div>

            <!-- Available Plans -->
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4">
                        <i class="bi bi-lightning-charge-fill text-warning me-2"></i>
                        Choose a Plan & Pay
                    </h5>

                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success rounded-3 mb-3">
                            <i class="bi bi-check-circle me-2"></i>
                            @TempData["Success"]
                        </div>
                    }

                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger rounded-3 mb-3">
                            <i class="bi bi-exclamation-triangle me-2"></i>
                            @TempData["Error"]
                        </div>
                    }

                    <div class="row g-3">
                        @if (ViewBag.Plans != null)
                        {
                            @foreach (var plan in ViewBag.Plans as
                                List<GymManagementSystem.Models.MembershipPlan>)
                            {
                                <div class="col-md-4">
                                    <div class="card border-2 rounded-4 h-100 plan-card"
                                         style="border-color:#f0f0f0;cursor:pointer;
                                        transition:all 0.3s ease;"
                                         onmouseover="this.style.borderColor='#ffc107';
                                        this.style.transform='translateY(-4px)';
                                        this.style.boxShadow='0 8px 25px rgba(255,193,7,0.2)'"
                                         onmouseout="this.style.borderColor='#f0f0f0';
                                        this.style.transform='translateY(0)';
                                        this.style.boxShadow='none'">
                                        <div class="card-body p-3 text-center">

                                            <div style="width:50px;height:50px;
                                                border-radius:12px;
                                                background:linear-gradient(135deg,#ffc107,#ff8c00);
                                                display:flex;align-items:center;
                                                justify-content:center;
                                                margin:0 auto 12px;">
                                                <i class="bi bi-award-fill text-dark"
                                                   style="font-size:1.3rem;"></i>
                                            </div>

                                            <h6 class="fw-bold">@plan.PlanName</h6>
                                            <h4 class="text-warning fw-bold my-2">
                                                Rs.@plan.Price.ToString("N0")
                                            </h4>
                                            <p class="text-muted small mb-1">
                                                <i class="bi bi-clock me-1"></i>
                                                @plan.DurationDays days
                                            </p>
                                            <p class="text-muted"
                                               style="font-size:0.75rem;">
                                                @plan.Description
                                            </p>

                                            <hr />

                                            @if (ViewBag.MemberDbId != null)
                                            {
                                                <!-- eSewa Pay Button -->
                                                <a asp-controller="ESewa"
                                                   asp-action="Pay"
                                                   asp-route-memberId="@ViewBag.MemberDbId"
                                                   asp-route-planId="@plan.PlanId"
                                                   class="btn btn-success btn-sm w-100 fw-bold py-2">
                                                    <i class="bi bi-phone-fill me-1"></i>
                                                    Pay with eSewa
                                                </a>
                                            }
                                            else
                                            {
                                                <div class="alert alert-warning small py-1 mb-0">
                                                    Contact admin to link your account
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                    </div>

                    <div class="alert alert-light border mt-4 small">
                        <i class="bi bi-info-circle text-warning me-1"></i>
                        <strong>eSewa Test:</strong>
                        ID: <code>9806800001</code>
                        Password: <code>Nepal@123</code>
                        MPIN: <code>1122</code>
                        OTP: <code>123456</code>
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>
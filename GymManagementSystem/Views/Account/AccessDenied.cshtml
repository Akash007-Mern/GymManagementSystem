@{
    ViewData["Title"] = "Access Denied";
    Layout = "~/Views/Shared/_StaticLayout.cshtml";
}

<div class="container text-center mt-5">
    <i class="bi bi-shield-x text-danger" style="font-size:5rem;"></i>
    <h2 class="fw-bold mt-3">Access Denied</h2>
    <p class="text-muted">You do not have permission to view this page.</p>
    <a asp-controller="Account" asp-action="Login" class="btn btn-warning fw-bold px-4">
        <i class="bi bi-box-arrow-in-right"></i> Back to Login
    </a>
</div>
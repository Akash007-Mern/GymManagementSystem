@model GymManagementSystem.Models.Payment
@{
    ViewData["Title"] = "Payment Details";
}

<div class="d-flex align-items-center mb-4">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm me-3">
        <i class="bi bi-arrow-left"></i>
    </a>
    <h2 class="page-title">
        <i class="bi bi-receipt text-warning me-2"></i>Payment Details
    </h2>
</div>

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-5">
        <div class="row">
            <div class="col-md-6">
                <h5 class="fw-bold mb-3 text-muted">Payment Information</h5>
                <dl class="row">
                    <dt class="col-sm-5 text-muted">Payment ID</dt>
                    <dd class="col-sm-7">#@Model.PaymentId</dd>

                    <dt class="col-sm-5 text-muted">Member</dt>
                    <dd class="col-sm-7 fw-bold">@Model.Member?.FullName</dd>

                    <dt class="col-sm-5 text-muted">Plan</dt>
                    <dd class="col-sm-7">@Model.Plan?.PlanName</dd>

                    <dt class="col-sm-5 text-muted">Amount Paid</dt>
                    <dd class="col-sm-7 fw-bold text-success fs-5">
                        Rs. @Model.AmountPaid.ToString("N0")
                    </dd>

                    <dt class="col-sm-5 text-muted">Payment Date</dt>
                    <dd class="col-sm-7">
                        @Model.PaymentDate.ToString("dd MMM yyyy")
                    </dd>

                    <dt class="col-sm-5 text-muted">Valid Until</dt>
                    <dd class="col-sm-7">
                        @Model.ValidUntil.ToString("dd MMM yyyy")
                        @if (Model.ValidUntil >= DateOnly.FromDateTime(DateTime.Now))
                        {
                            <span class="badge bg-success ms-2">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-danger ms-2">Expired</span>
                        }
                    </dd>

                    <dt class="col-sm-5 text-muted">Notes</dt>
                    <dd class="col-sm-7">@(Model.Notes ?? "No notes")</dd>
                </dl>
            </div>
        </div>

        <div class="d-flex gap-2 mt-3">
            <a asp-action="Edit" asp-route-id="@Model.PaymentId"
               class="btn btn-warning fw-bold px-4">
                <i class="bi bi-pencil me-1"></i> Edit
            </a>
            <a asp-action="Delete" asp-route-id="@Model.PaymentId"
               class="btn btn-outline-danger px-4">
                <i class="bi bi-trash me-1"></i> Delete
            </a>
        </div>
    </div>
</div>
@model IEnumerable<GymManagementSystem.Models.Payment>
@{
    ViewData["Title"] = "Payments";
}
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show rounded-4 mb-4">
        <i class="bi bi-check-circle-fill me-2"></i>
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show rounded-4 mb-4">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="page-title">
            <i class="bi bi-cash-stack text-warning me-2"></i>Payments
        </h2>
        <p class="page-subtitle">Track all member fee payments</p>
    </div>
    <a asp-action="Create" class="btn btn-warning fw-bold px-4">
        <i class="bi bi-plus-circle me-1"></i> Record Payment
    </a>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-cash-coin text-muted" style="font-size:4rem;"></i>
        <h5 class="mt-3 text-muted">No payments recorded yet</h5>
        <a asp-action="Create" class="btn btn-warning mt-2">Record First Payment</a>
    </div>
}
else
{
    <!-- Summary Cards -->
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card border-0 rounded-4 p-3 text-white"
                 style="background: linear-gradient(135deg,#43e97b,#38f9d7);">
                <p class="small mb-1 opacity-75">Total Payments</p>
                <h3 class="fw-bold mb-0">@Model.Count()</h3>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 rounded-4 p-3 text-white"
                 style="background: linear-gradient(135deg,#667eea,#764ba2);">
                <p class="small mb-1 opacity-75">Total Revenue</p>
                <h3 class="fw-bold mb-0">Rs. @Model.Sum(p => p.AmountPaid).ToString("N0")</h3>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 rounded-4 p-3 text-white"
                 style="background: linear-gradient(135deg,#f093fb,#f5576c);">
                <p class="small mb-1 opacity-75">This Month</p>
                <h3 class="fw-bold mb-0">
                    Rs. @Model.Where(p => p.PaymentDate.Month == DateTime.Now.Month
                                                                 && p.PaymentDate.Year == DateTime.Now.Year)
                    .Sum(p => p.AmountPaid).ToString("N0")
                </h3>
            </div>
        </div>
    </div>

    <!-- Payments Table -->
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-0">
            <table class="table table-hover mb-0 rounded-4 overflow-hidden">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Member</th>
                        <th>Plan</th>
                        <th>Amount</th>
                        <th>Payment Date</th>
                        <th>Valid Until</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var payment in Model)
                    {
                        <tr>
                            <td class="text-muted small">@payment.PaymentId</td>
                            <td>
                                <strong>@payment.Member?.FullName</strong>
                            </td>
                            <td>
                                <span class="badge bg-success-subtle text-success">
                                    @payment.Plan?.PlanName
                                </span>
                            </td>
                            <td class="fw-bold text-success">
                                Rs. @payment.AmountPaid.ToString("N0")
                            </td>
                            <td>@payment.PaymentDate.ToString("dd MMM yyyy")</td>
                            <td>@payment.ValidUntil.ToString("dd MMM yyyy")</td>
                            <td>
                                @if (payment.ValidUntil >= DateOnly.FromDateTime(DateTime.Now))
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Expired</span>
                                }
                            </td>
                            <td>
                                @if (payment.ValidUntil < DateOnly.FromDateTime(DateTime.Now))
                                {
                                    <a asp-controller="ESewa" asp-action="Pay"
                                       asp-route-memberId="@payment.MemberId"
                                       asp-route-planId="@payment.PlanId"
                                       class="btn btn-success btn-sm fw-bold"
                                       title="Renew with eSewa">
                                        <i class="bi bi-phone-fill"></i> eSewa
                                    </a>
                                }
                                <a asp-action="Details" asp-route-id="@payment.PaymentId"
                                   class="btn btn-outline-info btn-sm">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@payment.PaymentId"
                                   class="btn btn-outline-warning btn-sm">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@payment.PaymentId"
                                   class="btn btn-outline-danger btn-sm">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
@model GymManagementSystem.Models.Payment
@{
    ViewData["Title"] = "Delete Payment";
}

<div class="d-flex align-items-center mb-4">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm me-3">
        <i class="bi bi-arrow-left"></i>
    </a>
    <h2 class="page-title text-danger">
        <i class="bi bi-trash-fill me-2"></i>Delete Payment
    </h2>
</div>

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-5">
        <div class="alert alert-danger">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            Are you sure you want to delete this payment record?
        </div>

        <dl class="row mt-3">
            <dt class="col-sm-3 text-muted">Member</dt>
            <dd class="col-sm-9">@Model.Member?.FullName</dd>

            <dt class="col-sm-3 text-muted">Plan</dt>
            <dd class="col-sm-9">@Model.Plan?.PlanName</dd>

            <dt class="col-sm-3 text-muted">Amount</dt>
            <dd class="col-sm-9 fw-bold text-success">
                Rs. @Model.AmountPaid.ToString("N0")
            </dd>

            <dt class="col-sm-3 text-muted">Date</dt>
            <dd class="col-sm-9">@Model.PaymentDate.ToString("dd MMM yyyy")</dd>
        </dl>

        <form asp-action="Delete" class="mt-4">
            <input type="hidden" asp-for="PaymentId" />
            <button type="submit" class="btn btn-danger fw-bold px-5">
                <i class="bi bi-trash me-1"></i> Yes, Delete
            </button>
            <a asp-action="Index" class="btn btn-outline-secondary px-4 ms-2">
                Cancel
            </a>
        </form>
    </div>
</div>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FitZone Gym</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    <!-- SIMPLE TOP NAVBAR (no sidebar here) -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
        <div class="container">
            <!-- Brand -->
            <a class="navbar-brand fw-bold fs-4" href="/">
                <i class="bi bi-lightning-charge-fill text-warning"></i> FitZone
            </a>

            <!-- Mobile toggle -->
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#staticNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <!-- Nav links -->
            <div class="collapse navbar-collapse" id="staticNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">
                            <i class="bi bi-house-door"></i> Home
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Members" asp-action="Index">
                            <i class="bi bi-people"></i> Members
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Trainers" asp-action="Index">
                            <i class="bi bi-person-badge"></i> Trainers
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="MembershipPlans" asp-action="Index">
                            <i class="bi bi-card-list"></i> Plans
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Payments" asp-action="Index">
                            <i class="bi bi-cash-coin"></i> Payments
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Attendance" asp-action="Index">
                            <i class="bi bi-calendar-check"></i> Attendance
                        </a>
                    </li>
                    <li class="nav-item ms-2">
                        <a class="btn btn-warning fw-bold" asp-controller="Members" asp-action="Index">
                            <i class="bi bi-speedometer2"></i> Dashboard
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- FULL WIDTH CONTENT — no sidebar -->
    <main>
        @RenderBody()
    </main>

    <!-- FOOTER -->
    <footer class="bg-dark text-white text-center py-4 mt-5">
        <div class="container">
            <div class="row">
                <div class="col-md-4 text-md-start mb-2 mb-md-0">
                    <strong><i class="bi bi-lightning-charge-fill text-warning"></i> FitZone</strong>
                    <p class="small text-secondary mb-0">Professional Gym Management</p>
                </div>
                <div class="col-md-4 mb-2 mb-md-0">
                    <small class="text-secondary">© 2025 FitZone Gym. All rights reserved.</small>
                </div>
                <div class="col-md-4 text-md-end">
                    <small class="text-secondary">Built with ASP.NET Core MVC</small>
                </div>
            </div>
        </div>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
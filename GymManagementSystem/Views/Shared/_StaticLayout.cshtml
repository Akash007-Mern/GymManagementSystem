<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FitZone Gym</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

<!-- TOP NAVBAR -->
<nav class="navbar navbar-expand-lg navbar-dark sticky-top"
     style="background: rgba(15,15,30,0.98);
            border-bottom: 1px solid rgba(255,193,7,0.2);
            backdrop-filter: blur(10px);">
    <div class="container-fluid px-4">

        <!-- LOGO -->
        <a class="navbar-brand fw-bold fs-4 d-flex align-items-center gap-2"
           asp-controller="Home" asp-action="Index">
            <div style="background:linear-gradient(135deg,#ffc107,#ff8c00);
                        width:36px;height:36px;border-radius:8px;
                        display:flex;align-items:center;justify-content:center;">
                <i class="bi bi-lightning-charge-fill text-dark" style="font-size:1.1rem;"></i>
            </div>
            <span class="text-white">Fit<span class="text-warning">Zone</span></span>
        </a>

        <button class="navbar-toggler border-0" type="button"
                data-bs-toggle="collapse" data-bs-target="#mainNav">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="mainNav">
            <ul class="navbar-nav ms-auto align-items-center gap-2">
                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <li class="nav-item">
                        <span class="nav-link text-warning fw-semibold">
                            <i class="bi bi-person-circle me-1"></i>
                            @User.Identity.Name
                            <span class="badge bg-warning text-dark ms-1" style="font-size:0.65rem;">
                                @(User.IsInRole("Admin") ? "Admin" : "Member")
                            </span>
                        </span>
                    </li>
                    <li class="nav-item">
                        <a asp-controller="Account" asp-action="Logout"
                           class="btn btn-sm fw-bold px-3"
                           style="background:rgba(220,53,69,0.15);
                                  border:1px solid rgba(220,53,69,0.4);
                                  color:#ff6b7a;border-radius:8px;">
                            <i class="bi bi-box-arrow-right me-1"></i> Logout
                        </a>
                    </li>
                }
                else
                {
                    <li class="nav-item">
                        <a asp-controller="Account" asp-action="Login"
                           class="btn btn-warning btn-sm fw-bold px-4">
                            <i class="bi bi-box-arrow-in-right me-1"></i> Login
                        </a>
                    </li>
                }
            </ul>
        </div>
    </div>
</nav>

<!-- BODY WRAPPER -->
<div class="d-flex" style="min-height:calc(100vh - 56px);">

    <!-- SIDEBAR -->
    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        <div id="sidebar" class="sidebar-wrapper bg-dark text-white d-flex flex-column p-3"
             style="width:230px;min-width:230px;position:sticky;
                    top:56px;height:calc(100vh - 56px);overflow-y:auto;
                    transition:all 0.3s ease;box-shadow:2px 0 15px rgba(0,0,0,0.2);">

            @if (User.IsInRole("Admin"))
            {
                <p class="text-uppercase fw-bold mb-2 mt-1"
                   style="font-size:0.65rem;letter-spacing:1.5px;color:#6c757d;">
                    Main Menu
                </p>

                <a asp-controller="Home" asp-action="Index" class="sidebar-link">
                    <i class="bi bi-speedometer2"></i> Dashboard
                </a>
                <a asp-controller="Members" asp-action="Index" class="sidebar-link">
                    <i class="bi bi-people-fill"></i> Members
                </a>
                <a asp-controller="Trainers" asp-action="Index" class="sidebar-link">
                    <i class="bi bi-person-badge-fill"></i> Trainers
                </a>
                <a asp-controller="MembershipPlans" asp-action="Index" class="sidebar-link">
                    <i class="bi bi-card-checklist"></i> Plans
                </a>
                <a asp-controller="Payments" asp-action="Index" class="sidebar-link">
                    <i class="bi bi-cash-stack"></i> Payments
                </a>
                <a asp-controller="Attendance" asp-action="Index" class="sidebar-link">
                    <i class="bi bi-calendar2-check-fill"></i> Attendance
                </a>

                <hr style="border-color:rgba(255,255,255,0.1);" />

                <p class="text-uppercase fw-bold mb-2"
                   style="font-size:0.65rem;letter-spacing:1.5px;color:#6c757d;">
                    Reports
                </p>
                <a href="#" class="sidebar-link">
                    <i class="bi bi-bar-chart-fill"></i> Statistics
                </a>
                <a href="#" class="sidebar-link">
                    <i class="bi bi-download"></i> Export Data
                </a>
            }

            @if (User.IsInRole("Member"))
            {
                <p class="text-uppercase fw-bold mb-2 mt-1"
                   style="font-size:0.65rem;letter-spacing:1.5px;color:#6c757d;">
                    My Account
                </p>
                <a asp-controller="Account" asp-action="MyProfile" class="sidebar-link">
                    <i class="bi bi-person-circle"></i> My Profile
                </a>
            }

        </div>
    }

    <!-- MAIN CONTENT -->
    <div class="flex-grow-1 p-4" style="background:#f4f6f9;overflow-x:hidden;">
        @RenderBody()
    </div>

</div>

<!-- FOOTER -->
<footer class="bg-dark text-white text-center py-3"
        style="border-top:1px solid rgba(255,193,7,0.2);">
    <small class="text-secondary">
        © 2025 <span class="text-warning fw-bold">FitZone</span>
        Gym Management System. All rights reserved.
    </small>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

<script>
    // Highlight active sidebar link
    document.addEventListener('DOMContentLoaded', function () {
        const links = document.querySelectorAll('.sidebar-link');
        const current = window.location.pathname.toLowerCase();
        links.forEach(link => {
            const href = link.getAttribute('href')?.toLowerCase();
            if (href && current.startsWith(href) && href !== '/') {
                link.classList.add('active');
            } else if (href === '/' && current === '/') {
                link.classList.add('active');
            }
        });
    });
</script>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FitZone Gym</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold fs-4" asp-controller="Home" asp-action="Index">
                <i class="bi bi-lightning-charge-fill text-warning"></i> FitZone
            </a>

            <button class="navbar-toggler" type="button"
                    data-bs-toggle="collapse" data-bs-target="#staticNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="staticNav">
                <ul class="navbar-nav ms-auto align-items-center gap-2">

                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Home" asp-action="Index">
                                    <i class="bi bi-house-door"></i> Home
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Members" asp-action="Index">
                                    <i class="bi bi-people"></i> Members
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Trainers" asp-action="Index">
                                    <i class="bi bi-person-badge"></i> Trainers
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="MembershipPlans" asp-action="Index">
                                    <i class="bi bi-card-list"></i> Plans
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Payments" asp-action="Index">
                                    <i class="bi bi-cash-coin"></i> Payments
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Attendance" asp-action="Index">
                                    <i class="bi bi-calendar-check"></i> Attendance
                                </a>
                            </li>
                            <li class="nav-item">
                                <a asp-controller="Account" asp-action="Logout"
                                   class="btn btn-outline-danger btn-sm fw-bold ms-2">
                                    <i class="bi bi-box-arrow-right"></i> Logout
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-warning fw-semibold"
                                   asp-controller="Account" asp-action="MyProfile">
                                    <i class="bi bi-person-circle"></i> My Profile
                                </a>
                            </li>
                            <li class="nav-item">
                                <a asp-controller="Account" asp-action="Logout"
                                   class="btn btn-outline-danger btn-sm fw-bold">
                                    <i class="bi bi-box-arrow-right"></i> Logout
                                </a>
                            </li>
                        }
                    }
                    else
{
    <li class="nav-item">
        <a class="nav-link text-light me-2" asp-controller="Home" asp-action="Index">
            <i class="bi bi-house-door"></i> Home
        </a>
    </li>
    <li class="nav-item">
        <a asp-controller="Account" asp-action="Login"
           class="btn btn-warning fw-bold btn-sm me-1">
            <i class="bi bi-box-arrow-in-right"></i> Login
        </a>
    </li>
    <li class="nav-item">
        <a asp-controller="Account" asp-action="Register"
           class="btn btn-outline-light fw-bold btn-sm">
            <i class="bi bi-person-plus"></i> Register
        </a>
    </li>
}
                    
                </ul>
            </div>
        </div>
    </nav>

    <!-- ✅ THIS IS THE MOST IMPORTANT PART — DO NOT REMOVE -->
    <main role="main">
        @RenderBody()
    </main>
    <!-- ✅ END OF IMPORTANT PART -->
    <!-- FOOTER -->
    <footer class="bg-dark text-white text-center py-4 mt-5">
        <div class="container">
            <div class="row">
                <div class="col-md-4 text-md-start mb-2 mb-md-0">
                    <strong>
                        <i class="bi bi-lightning-charge-fill text-warning"></i> FitZone
                    </strong>
                    <p class="small text-secondary mb-0">Professional Gym Management</p>
                </div>
                <div class="col-md-4 mb-2 mb-md-0">
                    <small class="text-secondary">© 2025 FitZone Gym. All rights reserved.</small>
                </div>
                <div class="col-md-4 text-md-end">
                    <small class="text-secondary">Built with ASP.NET Core MVC</small>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
@model GymManagementSystem.Models.Trainer
@{
    ViewData["Title"] = "Trainer Details";
}

<div class="d-flex align-items-center mb-4">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm me-3">
        <i class="bi bi-arrow-left"></i>
    </a>
    <h2 class="page-title">
        <i class="bi bi-person-badge-fill text-danger me-2"></i>Trainer Details
    </h2>
</div>

<div class="row g-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm rounded-4 text-center p-4">
            <div style="width:90px; height:90px; border-radius:50%;
                background: linear-gradient(135deg,#f093fb,#f5576c);
                display:flex; align-items:center; justify-content:center;
                margin: 0 auto 15px;">
                <i class="bi bi-person-fill text-white" style="font-size:2.5rem;"></i>
            </div>
            <h4 class="fw-bold">@Model.FullName</h4>
            <span class="badge bg-danger px-3 py-2">@Model.Specialty</span>
            <hr />
            @if (Model.IsActive == true)
            {
                <span class="badge bg-success px-3 py-2">
                    <i class="bi bi-circle-fill me-1" style="font-size:0.5rem;"></i>Active
                </span>
            }
            else
            {
                <span class="badge bg-danger px-3 py-2">Inactive</span>
            }
        </div>
    </div>

    <div class="col-md-8">
        <div class="card border-0 shadow-sm rounded-4 p-4">
            <h5 class="fw-bold mb-4">Contact Information</h5>
            <dl class="row">
                <dt class="col-sm-4 text-muted">Phone</dt>
                <dd class="col-sm-8">@(Model.Phone ?? "Not provided")</dd>

                <dt class="col-sm-4 text-muted">Email</dt>
                <dd class="col-sm-8">@(Model.Email ?? "Not provided")</dd>

                <dt class="col-sm-4 text-muted">Join Date</dt>
                <dd class="col-sm-8">@Model.JoinDate.ToString("dd MMM yyyy")</dd>

                <dt class="col-sm-4 text-muted">Specialty</dt>
                <dd class="col-sm-8">@Model.Specialty</dd>
            </dl>

            <div class="d-flex gap-2 mt-3">
                <a asp-action="Edit" asp-route-id="@Model.TrainerId"
                   class="btn btn-warning fw-bold px-4">
                    <i class="bi bi-pencil me-1"></i> Edit
                </a>
                <a asp-action="Delete" asp-route-id="@Model.TrainerId"
                   class="btn btn-outline-danger px-4">
                    <i class="bi bi-trash me-1"></i> Delete
                </a>
            </div>
        </div>
    </div>
</div>
@{
    ViewData["Title"] = "Welcome to FitZone";
    Layout = "~/Views/Shared/_StaticLayout.cshtml";
}

<style>
    .hero-section {
        background: linear-gradient(135deg, #0f0c29, #302b63, #24243e);
        min-height: 92vh;
        display: flex;
        align-items: center;
        position: relative;
        overflow: hidden;
    }

        .hero-section::before {
            content: '';
            position: absolute;
            width: 600px;
            height: 600px;
            background: radial-gradient(circle, rgba(255,193,7,0.08) 0%, transparent 70%);
            top: -100px;
            right: -100px;
            border-radius: 50%;
        }

        .hero-section::after {
            content: '';
            position: absolute;
            width: 400px;
            height: 400px;
            background: radial-gradient(circle, rgba(102,126,234,0.1) 0%, transparent 70%);
            bottom: -50px;
            left: -50px;
            border-radius: 50%;
        }

    .hero-badge {
        display: inline-block;
        background: rgba(255,193,7,0.15);
        border: 1px solid rgba(255,193,7,0.3);
        color: #ffc107;
        padding: 6px 18px;
        border-radius: 50px;
        font-size: 0.8rem;
        font-weight: 600;
        letter-spacing: 1px;
        margin-bottom: 20px;
    }

    .hero-title {
        font-size: 3.8rem;
        font-weight: 800;
        line-height: 1.1;
        color: white;
    }

        .hero-title span {
            background: linear-gradient(135deg, #ffc107, #ff8c00);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

    .hero-desc {
        font-size: 1.1rem;
        color: rgba(255,255,255,0.6);
        max-width: 500px;
        line-height: 1.7;
    }

    .hero-btn-primary {
        background: linear-gradient(135deg, #ffc107, #ff8c00);
        color: #1a1a2e;
        font-weight: 700;
        padding: 14px 32px;
        border-radius: 12px;
        border: none;
        font-size: 0.95rem;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.3s ease;
        box-shadow: 0 8px 25px rgba(255,193,7,0.3);
    }

        .hero-btn-primary:hover {
            transform: translateY(-3px);
            box-shadow: 0 12px 35px rgba(255,193,7,0.4);
            color: #1a1a2e;
        }

    .hero-btn-secondary {
        background: rgba(255,255,255,0.08);
        color: white;
        font-weight: 600;
        padding: 14px 32px;
        border-radius: 12px;
        border: 1px solid rgba(255,255,255,0.15);
        font-size: 0.95rem;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.3s ease;
    }

        .hero-btn-secondary:hover {
            background: rgba(255,255,255,0.15);
            color: white;
            transform: translateY(-3px);
        }

    .floating-card {
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 16px;
        padding: 20px;
        backdrop-filter: blur(10px);
        animation: float 3s ease-in-out infinite;
    }

        .floating-card:nth-child(2) {
            animation-delay: 0.5s;
        }

        .floating-card:nth-child(3) {
            animation-delay: 1s;
        }

        .floating-card:nth-child(4) {
            animation-delay: 1.5s;
        }

    @@keyframes float {
        0%, 100% {
            transform: translateY(0px);
        }

        50% {
            transform: translateY(-8px);
        }
    }

    .stat-pill {
        background: rgba(255,255,255,0.08);
        border: 1px solid rgba(255,255,255,0.12);
        border-radius: 50px;
        padding: 8px 20px;
        color: white;
        font-size: 0.85rem;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .feature-section {
        background: #f8f9fa;
        padding: 80px 0;
    }

    .feature-card-new {
        background: white;
        border-radius: 20px;
        padding: 32px 24px;
        text-align: center;
        box-shadow: 0 4px 20px rgba(0,0,0,0.06);
        transition: all 0.3s ease;
        border: 1px solid #f0f0f0;
        height: 100%;
    }

        .feature-card-new:hover {
            transform: translateY(-8px);
            box-shadow: 0 16px 40px rgba(0,0,0,0.12);
        }

    .feature-icon {
        width: 70px;
        height: 70px;
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 20px;
        font-size: 1.8rem;
    }

    .stats-section {
        background: linear-gradient(135deg, #1a1a2e, #16213e);
        padding: 60px 0;
    }

    .stat-box {
        text-align: center;
        color: white;
        padding: 20px;
    }

        .stat-box h2 {
            font-size: 3rem;
            font-weight: 800;
            background: linear-gradient(135deg, #ffc107, #ff8c00);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
</style>

<!-- HERO SECTION -->
<div class="hero-section">
    <div class="container position-relative" style="z-index:1;">
        <div class="row align-items-center">

            <!-- LEFT SIDE -->
            <div class="col-lg-6 text-white">
                <div class="hero-badge">
                    <i class="bi bi-lightning-charge-fill me-1"></i>
                    PROFESSIONAL GYM MANAGEMENT
                </div>

                <h1 class="hero-title mb-4">
                    Manage Your<br />
                    Gym with <span>FitZone</span>
                </h1>

                <p class="hero-desc mb-5">
                    A complete gym management system — track members,
                    trainers, payments and attendance all from one
                    powerful dashboard.
                </p>

                <div class="d-flex gap-3 flex-wrap mb-5">
                    <a asp-controller="Account" asp-action="Login"
                       class="hero-btn-primary">
                        <i class="bi bi-speedometer2"></i>
                        Go to Dashboard
                    </a>
                    <a asp-controller="Account" asp-action="Register"
                       class="hero-btn-secondary">
                        <i class="bi bi-person-plus"></i>
                        Join as Member
                    </a>
                </div>

                <!-- Mini stats row -->
                <div class="d-flex gap-3 flex-wrap">
                    <div class="stat-pill">
                        <i class="bi bi-people-fill text-warning"></i>
                        Member Tracking
                    </div>
                    <div class="stat-pill">
                        <i class="bi bi-cash-coin text-warning"></i>
                        Payment Records
                    </div>
                    <div class="stat-pill">
                        <i class="bi bi-calendar-check text-warning"></i>
                        Attendance
                    </div>
                </div>
            </div>

            <!-- RIGHT SIDE — Floating Cards -->
            <div class="col-lg-6 mt-5 mt-lg-0">
                <div class="row g-3">

                    <div class="col-6">
                        <div class="floating-card">
                            <div class="d-flex align-items-center gap-3 mb-2">
                                <div style="width:40px;height:40px;border-radius:10px;
                                    background:linear-gradient(135deg,#667eea,#764ba2);
                                    display:flex;align-items:center;justify-content:center;">
                                    <i class="bi bi-people-fill text-white"></i>
                                </div>
                                <div class="text-white fw-bold">Members</div>
                            </div>
                            <div class="text-warning fw-bold" style="font-size:1.5rem;">
                                Track All
                            </div>
                            <div style="color:rgba(255,255,255,0.5);font-size:0.8rem;">
                                Active & Inactive
                            </div>
                        </div>
                    </div>

                    <div class="col-6">
                        <div class="floating-card">
                            <div class="d-flex align-items-center gap-3 mb-2">
                                <div style="width:40px;height:40px;border-radius:10px;
                                    background:linear-gradient(135deg,#f093fb,#f5576c);
                                    display:flex;align-items:center;justify-content:center;">
                                    <i class="bi bi-cash-coin text-white"></i>
                                </div>
                                <div class="text-white fw-bold">Payments</div>
                            </div>
                            <div class="text-warning fw-bold" style="font-size:1.5rem;">
                                Auto Track
                            </div>
                            <div style="color:rgba(255,255,255,0.5);font-size:0.8rem;">
                                Monthly Revenue
                            </div>
                        </div>
                    </div>

                    <div class="col-6">
                        <div class="floating-card">
                            <div class="d-flex align-items-center gap-3 mb-2">
                                <div style="width:40px;height:40px;border-radius:10px;
                                    background:linear-gradient(135deg,#4facfe,#00f2fe);
                                    display:flex;align-items:center;justify-content:center;">
                                    <i class="bi bi-calendar-check text-white"></i>
                                </div>
                                <div class="text-white fw-bold">Attendance</div>
                            </div>
                            <div class="text-warning fw-bold" style="font-size:1.5rem;">
                                Daily Log
                            </div>
                            <div style="color:rgba(255,255,255,0.5);font-size:0.8rem;">
                                Check-in & Out
                            </div>
                        </div>
                    </div>

                    <div class="col-6">
                        <div class="floating-card">
                            <div class="d-flex align-items-center gap-3 mb-2">
                                <div style="width:40px;height:40px;border-radius:10px;
                                    background:linear-gradient(135deg,#43e97b,#38f9d7);
                                    display:flex;align-items:center;justify-content:center;">
                                    <i class="bi bi-person-badge-fill text-white"></i>
                                </div>
                                <div class="text-white fw-bold">Trainers</div>
                            </div>
                            <div class="text-warning fw-bold" style="font-size:1.5rem;">
                                Manage
                            </div>
                            <div style="color:rgba(255,255,255,0.5);font-size:0.8rem;">
                                Specialties & Info
                            </div>
                        </div>
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>

<!-- STATS SECTION -->
<div class="stats-section">
    <div class="container">
        <div class="row g-4">
            <div class="col-md-3">
                <div class="stat-box">
                    <h2>100%</h2>
                    <p class="text-white-50 mb-0">Free to Use</p>
                </div>
            </div>
            <div class="col-md-3">
                <div class="stat-box">
                    <h2>5+</h2>
                    <p class="text-white-50 mb-0">Core Modules</p>
                </div>
            </div>
            <div class="col-md-3">
                <div class="stat-box">
                    <h2>2</h2>
                    <p class="text-white-50 mb-0">User Roles</p>
                </div>
            </div>
            <div class="col-md-3">
                <div class="stat-box">
                    <h2>PDF</h2>
                    <p class="text-white-50 mb-0">Export Reports</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- FEATURES SECTION -->
<div class="feature-section" id="features">
    <div class="container">
        <div class="text-center mb-5">
            <div class="hero-badge" style="background:rgba(102,126,234,0.1);
                border-color:rgba(102,126,234,0.3);color:#667eea;">
                FEATURES
            </div>
            <h2 class="fw-bold mt-2" style="font-size:2.2rem;">
                Everything You Need
            </h2>
            <p class="text-muted">
                Manage your entire gym from one place
            </p>
        </div>

        <div class="row g-4">
            <div class="col-md-4">
                <div class="feature-card-new">
                    <div class="feature-icon"
                         style="background:linear-gradient(135deg,#667eea20,#764ba220);">
                        <i class="bi bi-people-fill text-primary"></i>
                    </div>
                    <h5 class="fw-bold">Member Management</h5>
                    <p class="text-muted small">
                        Add, edit, view and manage all gym members.
                        Track active and inactive members easily.
                    </p>
                    <a asp-controller="Account" asp-action="Login"
                       class="btn btn-sm btn-primary px-4 fw-bold">
                        Manage →
                    </a>
                </div>
            </div>

            <div class="col-md-4">
                <div class="feature-card-new">
                    <div class="feature-icon"
                         style="background:linear-gradient(135deg,#f093fb20,#f5576c20);">
                        <i class="bi bi-person-badge-fill text-danger"></i>
                    </div>
                    <h5 class="fw-bold">Trainer Management</h5>
                    <p class="text-muted small">
                        Manage trainers with their specialties,
                        contact info and assign them to members.
                    </p>
                    <a asp-controller="Account" asp-action="Login"
                       class="btn btn-sm btn-danger px-4 fw-bold">
                        Manage →
                    </a>
                </div>
            </div>

            <div class="col-md-4">
                <div class="feature-card-new">
                    <div class="feature-icon"
                         style="background:linear-gradient(135deg,#43e97b20,#38f9d720);">
                        <i class="bi bi-cash-stack text-success"></i>
                    </div>
                    <h5 class="fw-bold">Payment Tracking</h5>
                    <p class="text-muted small">
                        Record all fee payments, track monthly revenue
                        and get alerts for expiring memberships.
                    </p>
                    <a asp-controller="Account" asp-action="Login"
                       class="btn btn-sm btn-success px-4 fw-bold">
                        Manage →
                    </a>
                </div>
            </div>

            <div class="col-md-4">
                <div class="feature-card-new">
                    <div class="feature-icon"
                         style="background:linear-gradient(135deg,#4facfe20,#00f2fe20);">
                        <i class="bi bi-calendar2-check-fill text-info"></i>
                    </div>
                    <h5 class="fw-bold">Attendance System</h5>
                    <p class="text-muted small">
                        Mark daily attendance with check-in and
                        check-out times. Track who is inside the gym.
                    </p>
                    <a asp-controller="Account" asp-action="Login"
                       class="btn btn-sm btn-info px-4 fw-bold text-white">
                        Manage →
                    </a>
                </div>
            </div>

            <div class="col-md-4">
                <div class="feature-card-new">
                    <div class="feature-icon"
                         style="background:linear-gradient(135deg,#ffc10720,#ff8c0020);">
                        <i class="bi bi-card-checklist text-warning"></i>
                    </div>
                    <h5 class="fw-bold">Membership Plans</h5>
                    <p class="text-muted small">
                        Create monthly, quarterly and yearly plans
                        with custom pricing and durations.
                    </p>
                    <a asp-controller="Account" asp-action="Login"
                       class="btn btn-sm btn-warning px-4 fw-bold">
                        Manage →
                    </a>
                </div>
            </div>

            <div class="col-md-4">
                <div class="feature-card-new">
                    <div class="feature-icon"
                         style="background:linear-gradient(135deg,#a8edea20,#fed6e320);">
                        <i class="bi bi-file-earmark-pdf-fill text-danger"></i>
                    </div>
                    <h5 class="fw-bold">PDF Export</h5>
                    <p class="text-muted small">
                        Export members and payment data as
                        professional PDF reports with one click.
                    </p>
                    <a asp-controller="Account" asp-action="Login"
                       class="btn btn-sm btn-outline-danger px-4 fw-bold">
                        Export →
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- CTA SECTION -->
<div style="background:linear-gradient(135deg,#1a1a2e,#16213e);padding:80px 0;">
    <div class="container text-center">
        <h2 class="text-white fw-bold mb-3" style="font-size:2.2rem;">
            Ready to Get Started?
        </h2>
        <p class="text-white-50 mb-4">
            Login as Admin to manage your gym or register as a member.
        </p>
        <div class="d-flex gap-3 justify-content-center flex-wrap">
            <a asp-controller="Account" asp-action="Login"
               class="hero-btn-primary">
                <i class="bi bi-box-arrow-in-right"></i>
                Admin Login
            </a>
            <a asp-controller="Account" asp-action="Register"
               class="hero-btn-secondary">
                <i class="bi bi-person-plus"></i>
                Member Register
            </a>
        </div>
    </div>
</div>
@{
    ViewData["Title"] = "Dashboard";
}

<!-- PAGE HEADER -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="page-title">
            <i class="bi bi-speedometer2 text-warning me-2"></i>Dashboard
        </h2>
        <p class="page-subtitle">
            Welcome back, Admin! Here's what's happening today.
        </p>
    </div>
    <div class="text-muted small">
        <i class="bi bi-calendar3 me-1"></i>
        @DateTime.Now.ToString("dddd, dd MMMM yyyy")
    </div>
</div>

<!-- STATS ROW 1 -->
<div class="row g-4 mb-4">

    <div class="col-md-3">
        <div class="card border-0 rounded-4 p-4 text-white shadow-sm"
             style="background: linear-gradient(135deg,#667eea,#764ba2);">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="small mb-1 opacity-75">Total Members</p>
                    <h2 class="fw-bold mb-0">@ViewBag.TotalMembers</h2>
                    <small class="opacity-75">
                        @ViewBag.ActiveMembers Active
                    </small>
                </div>
                <div style="font-size:2.5rem; opacity:0.25;">
                    <i class="bi bi-people-fill"></i>
                </div>
            </div>
            <div class="mt-3">
                <a asp-controller="Members" asp-action="Index"
                   class="btn btn-sm btn-light btn-outline fw-bold"
                   style="background:rgba(255,255,255,0.15);
                    border:1px solid rgba(255,255,255,0.3);
                    color:white; font-size:0.75rem;">
                    View All →
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card border-0 rounded-4 p-4 text-white shadow-sm"
             style="background: linear-gradient(135deg,#f093fb,#f5576c);">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="small mb-1 opacity-75">Trainers</p>
                    <h2 class="fw-bold mb-0">@ViewBag.TotalTrainers</h2>
                    <small class="opacity-75">
                        @ViewBag.ActiveTrainers Active
                    </small>
                </div>
                <div style="font-size:2.5rem; opacity:0.25;">
                    <i class="bi bi-person-badge-fill"></i>
                </div>
            </div>
            <div class="mt-3">
                <a asp-controller="Trainers" asp-action="Index"
                   class="btn btn-sm"
                   style="background:rgba(255,255,255,0.15);
                    border:1px solid rgba(255,255,255,0.3);
                    color:white; font-size:0.75rem;">
                    View All →
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card border-0 rounded-4 p-4 text-white shadow-sm"
             style="background: linear-gradient(135deg,#4facfe,#00f2fe);">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="small mb-1 opacity-75">Today's Attendance</p>
                    <h2 class="fw-bold mb-0">@ViewBag.TodayAttendance</h2>
                    <small class="opacity-75">
                        @ViewBag.StillInside Still Inside
                    </small>
                </div>
                <div style="font-size:2.5rem; opacity:0.25;">
                    <i class="bi bi-calendar2-check-fill"></i>
                </div>
            </div>
            <div class="mt-3">
                <a asp-controller="Attendance" asp-action="Index"
                   class="btn btn-sm"
                   style="background:rgba(255,255,255,0.15);
                    border:1px solid rgba(255,255,255,0.3);
                    color:white; font-size:0.75rem;">
                    View All →
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card border-0 rounded-4 p-4 text-white shadow-sm"
             style="background: linear-gradient(135deg,#43e97b,#38f9d7);">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="small mb-1 opacity-75">Monthly Revenue</p>
                    <h2 class="fw-bold mb-0">
                        Rs.@ViewBag.MonthlyRevenue.ToString("N0")
                    </h2>
                    <small class="opacity-75">
                        Total: Rs.@ViewBag.TotalRevenue.ToString("N0")
                    </small>
                </div>
                <div style="font-size:2.5rem; opacity:0.25;">
                    <i class="bi bi-cash-coin"></i>
                </div>
            </div>
            <div class="mt-3">
                <a asp-controller="Payments" asp-action="Index"
                   class="btn btn-sm"
                   style="background:rgba(255,255,255,0.15);
                    border:1px solid rgba(255,255,255,0.3);
                    color:white; font-size:0.75rem;">
                    View All →
                </a>
            </div>
        </div>
    </div>

</div>

<!-- QUICK ACTION BUTTONS -->
<div class="row g-3 mb-4">
    <div class="col-12">
        <div class="card border-0 shadow-sm rounded-4 p-3">
            <div class="d-flex align-items-center gap-3 flex-wrap">
                <span class="fw-bold text-muted small">QUICK ACTIONS:</span>
                <a asp-controller="Members" asp-action="Create"
                   class="btn btn-sm btn-primary fw-bold">
                    <i class="bi bi-person-plus me-1"></i> Add Member
                </a>
                <a asp-controller="Trainers" asp-action="Create"
                   class="btn btn-sm btn-danger fw-bold">
                    <i class="bi bi-person-badge me-1"></i> Add Trainer
                </a>
                <a asp-controller="Payments" asp-action="Create"
                   class="btn btn-sm btn-warning fw-bold">
                    <i class="bi bi-cash-coin me-1"></i> Record Payment
                </a>
                <a asp-controller="Attendance" asp-action="Create"
                   class="btn btn-sm btn-info fw-bold text-white">
                    <i class="bi bi-calendar-plus me-1"></i> Mark Attendance
                </a>
                <a asp-controller="MembershipPlans" asp-action="Create"
                   class="btn btn-sm btn-success fw-bold">
                    <i class="bi bi-card-plus me-1"></i> Add Plan
                </a>
            </div>
        </div>
    </div>
</div>

<!-- RECENT MEMBERS + RECENT PAYMENTS -->
<div class="row g-4">

    <!-- Recent Members -->
    <div class="col-md-6">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="fw-bold mb-0">
                        <i class="bi bi-people-fill text-primary me-2"></i>
                        Recent Members
                    </h5>
                    <a asp-controller="Members" asp-action="Index"
                       class="btn btn-sm btn-outline-primary">
                        View All
                    </a>
                </div>

                @if (ViewBag.RecentMembers != null)
                {
                    @foreach (var member in ViewBag.RecentMembers)
                    {
                        <div class="d-flex align-items-center py-2 border-bottom">
                            <div style="width:38px; height:38px; border-radius:50%;
                                background:linear-gradient(135deg,#667eea,#764ba2);
                                display:flex; align-items:center;
                                justify-content:center; flex-shrink:0;">
                                <i class="bi bi-person-fill text-white small"></i>
                            </div>
                            <div class="ms-3 flex-grow-1">
                                <div class="fw-semibold small">@member.FullName</div>
                                <div class="text-muted" style="font-size:0.75rem;">
                                    @member.Plan?.PlanName ?? "No Plan"
                                </div>
                            </div>
                            <div>
                                @if (member.IsActive == true)
                                {
                                    <span class="badge bg-success-subtle text-success">
                                        Active
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-danger-subtle text-danger">
                                        Inactive
                                    </span>
                                }
                            </div>
                        </div>
                    }
                }
                else
                {
                    <p class="text-muted small text-center py-3">No members yet</p>
                }
            </div>
        </div>
    </div>

    <!-- Recent Payments -->
    <div class="col-md-6">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="fw-bold mb-0">
                        <i class="bi bi-cash-stack text-success me-2"></i>
                        Recent Payments
                    </h5>
                    <a asp-controller="Payments" asp-action="Index"
                       class="btn btn-sm btn-outline-success">
                        View All
                    </a>
                </div>

                @if (ViewBag.RecentPayments != null)
                {
                    @foreach (var payment in ViewBag.RecentPayments)
                    {
                        <div class="d-flex align-items-center py-2 border-bottom">
                            <div style="width:38px; height:38px; border-radius:50%;
                                background:linear-gradient(135deg,#43e97b,#38f9d7);
                                display:flex; align-items:center;
                                justify-content:center; flex-shrink:0;">
                                <i class="bi bi-cash text-white small"></i>
                            </div>
                            <div class="ms-3 flex-grow-1">
                                <div class="fw-semibold small">
                                    @payment.Member?.FullName
                                </div>
                                <div class="text-muted" style="font-size:0.75rem;">
                                    @payment.Plan?.PlanName —
                                    @payment.PaymentDate.ToString("dd MMM yyyy")
                                </div>
                            </div>
                            <div class="fw-bold text-success small">
                                Rs.@payment.AmountPaid.ToString("N0")
                            </div>
                        </div>
                    }
                }
                else
                {
                    <p class="text-muted small text-center py-3">
                        No payments yet
                    </p>
                }
            </div>
        </div>
    </div>

</div>